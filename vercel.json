{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "vercel-backend/index.js" },
    { "source": "/uploads/(.*)", "destination": "vercel-backend/index.js" },
    { "source": "/(.*)", "destination": "/" }
  ]
}
