{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "vercel-backend/index.js",
      "use": "@vercel/node",
      "config": { "includeFiles": ["server/**"] }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "vercel-backend/index.js" },
    { "src": "/uploads/(.*)", "dest": "vercel-backend/index.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
