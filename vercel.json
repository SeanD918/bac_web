{
  "version": 2,
  "builds": [
    {
      "src": "vercel-backend/index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["server/**"]
      }
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "vercel-backend/index.js" },
    { "source": "/uploads/(.*)", "destination": "vercel-backend/index.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
